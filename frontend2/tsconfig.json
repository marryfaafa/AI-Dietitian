{
  "compilerOptions": {
    "target": "ES2020", "module": "ESNext", "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true, "moduleResolution": "bundler", "isolatedModules": true,
    "noEmit": true, "jsx": "preserve", "strict": false,
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["src/**/*", "env.d.ts"]
}
